# ── Required (for production) ──────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# JWT_SECRET=change-me

# ── Authentication ────────────────────────────────────────
# AUTH_ENABLED=false                    # Disable for local dev
# JWT_EXPIRY=7d

# ── Email (optional, logs to console if unset) ───────────
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Currano Farms <onboarding@resend.dev>
# ADMIN_EMAIL=you@example.com
# APP_URL=https://currano-farms.onrender.com

# ── Stripe (optional, disables payments if unset) ────────
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_PRICE_ID=price_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── Bot Protection (optional) ────────────────────────────
# TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ── Deployment ───────────────────────────────────────────
# PORT=3001
# NODE_ENV=production
# SERVE_DIR=svelte-app/build
# ALLOWED_ORIGINS=https://currano-farms.com,http://localhost:5173
